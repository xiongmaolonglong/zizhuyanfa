# 后端环境配置示例
# 复制此文件为 .env 并修改相应值

NODE_ENV=development
PORT=3010

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ad_workflow
DB_USER=root
DB_PASSWORD=

# JWT 配置（生产环境必须使用强随机密钥）
JWT_SECRET=change-me-to-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# 超级管理员配置（与租户账号完全隔离）
SUPER_ADMIN_PHONE=13900000000
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 微信小程序配置（可选）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TEMPLATE_STATUS_CHANGE=
WECHAT_TEMPLATE_ASSIGNED=
WECHAT_TEMPLATE_COMPLETED=
WECHAT_TEMPLATE_REJECTED=
